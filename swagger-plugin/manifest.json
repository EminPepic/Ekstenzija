{
  "manifest_version": 3,
  "name": "Swagger Service Tester",
  "short_name": "Swagger Tester",
  "version": "1.0.1",
  "description": "Automatic testing of REST services using Swagger/OpenAPI documentation",
  "homepage_url": "https://eminpepic.github.io/Ekstenzija/",
  "privacy_policy": "https://eminpepic.github.io/Ekstenzija/privacy-policy.html",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "optional_host_permissions": [
    "http://localhost:3000/*"
  ]
}
